{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "routes": [
    { "src": "/playground$", "dest": "/", "check": true },
    { "src": "/playground/(.*)", "dest": "/$1", "check": true },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
