export function a() {
    return (a = Object.assign ? Object.assign.bind() : function(e) {
        for(let t = 1; t < arguments.length; t++){
            const n = arguments[t];
            for(const a in n){
                if (Object.prototype.hasOwnProperty.call(n, a)) {
                    e[a] = n[a];
                }
            }
        }
        return e;
    }).apply(this, arguments);
}
