    "build": ["npx", "--yes", "pnpm@9.12.3", "run", "build"],
    "inputs": ["dist"],
    "notes": "Public Vue 3 + Vite todo app with router and multiple SFCs."
  },
  {
    "name": "vue3-realworld-example-app",
    "enabled": false,
    "tier": "medium",
    "bundler": "vite",
    "repo": "https://github.com/mutoe/vue3-realworld-example-app.git",
    "ref": "a3b07312d4c416c3976a3012e64cf39053060708",
    "install": ["npx", "--yes", "pnpm@10.33.0", "install", "--frozen-lockfile", "--ignore-scripts"],
    "build": ["npx", "--yes", "pnpm@10.33.0", "run", "build"],
    "inputs": ["dist"],
    "notes": "Public Vue 3 RealWorld app with routing, Pinia, auth flows, and CRUD screens."
  },
  {
    "name": "vue-cart-pinia",
    "enabled": false,
    "tier": "medium",
    "bundler": "vite",
    "repo": "https://github.com/wobsoriano/vue-cart.git",
    "ref": "0545629288a1fb3a9f641274d2c983c05dc24577",
    "install": ["npm", "install", "--silent", "--no-audit", "--no-fund"],
    "build": ["npx", "vite", "build"],
    "inputs": ["dist"],
    "notes": "Public Vue 3 + Pinia shopping-cart app with router, Tailwind/daisyUI classes, and multiple app SFCs. Uses vite build directly because its pinned vue-tsc is not compatible with current TypeScript on modern Node."
  },
  {
    "name": "module-federation-vue3-home-webpack5",
    "enabled": true,
    "tier": "smoke",
    "bundler": "webpack5",
    "repo": "https://github.com/module-federation/module-federation-examples.git",
    "ref": "583a1551e96a5a6418691891be9f04c1d15d6f8f",
    "subdir": "vue3-demo/home",
    "sparse": ["vue3-demo"],
    "install": ["npm", "install", "--silent", "--no-audit", "--no-fund"],
    "build": ["npm", "run", "build"],
    "inputs": ["dist"],
    "notes": "Pinned webpack 5 + vue-loader Module Federation packaging smoke. Its ordinary SFCs use separate render transforms and the project disables minimization, so inline script-setup and minified coverage comes from the compiler matrix instead."
  },
  {
    "name": "module-federation-vue3-layout-webpack5",
    "enabled": false,
    "tier": "small",
    "bundler": "webpack5",
    "repo": "https://github.com/module-federation/module-federation-examples.git",
    "ref": "583a1551e96a5a6418691891be9f04c1d15d6f8f",
    "subdir": "vue3-demo/layout",
    "sparse": ["vue3-demo"],
    "install": ["npm", "install", "--silent", "--no-audit", "--no-fund"],
    "build": ["npm", "run", "build"],
    "inputs": ["dist"],
    "notes": "Public Vue 3 webpack 5 Module Federation host consuming remote Vue components. Useful for non-Vite coverage and fallback accounting."
  },
  {
    "name": "vitepress-docs",
    "enabled": false,
    "tier": "large",
    "bundler": "vitepress",
    "repo": "https://github.com/vuejs/vitepress.git",
    "ref": "v1.6.4",
    "install": ["npx", "--yes", "pnpm@9.15.4", "install", "--frozen-lockfile"],
    "build": ["npx", "--yes", "pnpm@9.15.4", "run", "docs:build"],
    "inputs": ["docs/.vitepress/dist"],
    "notes": "Large public docs site. Run explicitly with --case vitepress-docs."
  }
]
