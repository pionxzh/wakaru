[
  {
    "name": "vite5-template-vue",
    "enabled": true,
    "tier": "smoke",
    "bundler": "vite",
    "repo": "https://github.com/vitejs/vite.git",
    "ref": "v5.4.0",
    "subdir": "packages/create-vite/template-vue",
    "sparse": ["packages/create-vite/template-vue"],
    "install": ["npm", "install", "--silent", "--no-audit", "--no-fund"],
    "build": ["npm", "run", "build"],
    "inputs": ["dist"],
    "notes": "Official Vite Vue starter pinned to Vite 5."
  },
  {
    "name": "vite6-template-vue",
