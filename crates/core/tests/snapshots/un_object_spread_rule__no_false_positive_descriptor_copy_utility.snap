function copyProps(target) {
    for(let i = 1; i < arguments.length; i++){
        const source = arguments[i];
        Object.defineProperty(target, "meta", {
            value: source,
            enumerable: false
        });
    }
    return target;
}
const x = copyProps({}, source);
