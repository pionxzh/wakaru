function m(e, t) {
    if (e == null) {
        return {};
    }
    const n = {};
    const i = Object.keys(e);
    for(let r = 0; r < i.length; r++){
        if (!(t.indexOf(i[r]) < 0)) {
            n[i[r]] = e[i[r]];
        }
    }
    return n;
}
